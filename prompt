package parser

import (
	"zug/lexer"
)

type Parser struct {
	Root    *[]*Node
	Current *[]*Node
	Last    []*[]*Node
}

type NodeClass int

const (
	UnkownNode NodeClass = iota
)

type Node struct {
	Class NodeClass
	Value any
}

func NewParser(tokens *[]lexer.Token) Parser {
	var parser Parser
	var newNodeRoot []*Node

	parser.Current = &newNodeRoot
	parser.Root = &newNodeRoot
	parser.Last = append(parser.Last, &newNodeRoot)

	return parser
}

func (p *Parser) Parse(tokens *[]lexer.Token) *[]*Node {

	cop := []lexer.Token{}
	var line uint = 1

	save := func() {
		p.mast(&cop)
		cop = cop[:0]
	}

	for _, token := range *tokens {
		if token.Line != line {
			if len(cop) != 0 {
				save()
			}
			line = token.Line
		} else if token.Type == lexer.EOF || token.Type == lexer.EOL {
			if len(cop) != 0 {
				save()
			}
		}
		if token.Type != lexer.EOF && token.Type != lexer.EOL {
			cop = append(cop, token)
		}
	}

	return p.Root
}

